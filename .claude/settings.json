{
  "permissions": {
    "allow": [
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo test *)",
      "Bash(cargo run --bin sandbox *)",
      "Bash(cargo clippy *)",
      "Bash(cargo fmt *)",
      "Bash(rustup *)",
      "Bash(wasm-tools *)",
      "Bash(rustc -vV *)"
    ],
    "deny": [
      "Bash(cargo publish *)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
