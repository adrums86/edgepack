# edgepack — Environment Variables
#
# Copy this file and set values for your deployment target.
# Not all variables are required — see deploy/README.md for platform-specific guides.

# =============================================================================
# Cache Store (required)
# =============================================================================

# Backend type: redis_http (default), redis_tcp, cloudflare_kv, http_kv
CACHE_BACKEND=redis_http

# Store endpoint and auth — used by redis_http and redis_tcp backends.
# Backward-compatible aliases: REDIS_URL / REDIS_TOKEN
STORE_URL=https://your-redis.upstash.io
STORE_TOKEN=your-redis-token

# Optional: separate token for cache encryption key derivation (defaults to STORE_TOKEN)
# CACHE_ENCRYPTION_TOKEN=your-encryption-token

# =============================================================================
# Cache TTLs (optional — sensible defaults)
# =============================================================================

# CACHE_MAX_AGE_SEGMENTS=31536000       # 1 year (segments + init)
# CACHE_MAX_AGE_MANIFEST_LIVE=1         # 1 second (live manifests)
# CACHE_MAX_AGE_MANIFEST_FINAL=31536000 # 1 year (finalized/VOD manifests)

# =============================================================================
# DRM / SPEKE 2.0 (required for encrypted content)
# =============================================================================

SPEKE_URL=https://your-drm-provider.com/speke/v2

# Auth — use ONE of these three methods:
SPEKE_BEARER_TOKEN=your-bearer-token
# SPEKE_API_KEY=your-api-key
# SPEKE_API_KEY_HEADER=x-api-key
# SPEKE_USERNAME=user
# SPEKE_PASSWORD=pass

# =============================================================================
# Cloudflare Workers KV (only with CACHE_BACKEND=cloudflare_kv + cloudflare feature)
# =============================================================================

# CF_ACCOUNT_ID=your-cf-account-id
# CF_KV_NAMESPACE_ID=your-kv-namespace-id
# CF_API_TOKEN=your-cf-api-token

# =============================================================================
# Generic HTTP KV (only with CACHE_BACKEND=http_kv)
# =============================================================================

# HTTP_KV_BASE_URL=https://your-kv-api.example.com/v1
# HTTP_KV_AUTH_HEADER=Authorization
# HTTP_KV_AUTH_VALUE=Bearer your-token

# =============================================================================
# JIT Packaging (optional — disabled by default)
# =============================================================================

# JIT_ENABLED=false
# JIT_SOURCE_URL_PATTERN=https://origin.example.com/{content_id}/manifest.m3u8
# JIT_DEFAULT_TARGET_SCHEME=cenc
# JIT_DEFAULT_CONTAINER_FORMAT=cmaf
# JIT_LOCK_TTL=30
